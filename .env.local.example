# =============================================================
# LEOKOKO website environment variables
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored — never commit real secrets.
# =============================================================

# ---- Spotify Web API ----
# Get these from https://developer.spotify.com/dashboard
# 1. Create an app
# 2. Copy Client ID and Client Secret here
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_ARTIST_ID=6yLIpvQqRMGVe8eYUBI8Hw

# ---- YouTube Data API v3 ----
# Get an API key at https://console.cloud.google.com/
# Enable "YouTube Data API v3" for your project, then create an API key.
YOUTUBE_API_KEY=
# Use the channel handle (we'll resolve to channel ID at runtime)
YOUTUBE_CHANNEL_HANDLE=@officialleokoko

# ---- Supabase (chat + auth) ----
# Create a project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
