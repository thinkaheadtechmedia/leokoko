# ============================================================
# LEOKOKO — Environment variables
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local` to git.
# ============================================================

# --- Spotify (Music page) ---
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Spotify artist ID (the part after /artist/ in the artist URL).
# Defaults to 6yLIpvQqRMGVe8eYUBI8Hw — change if your artist ID differs.
SPOTIFY_ARTIST_ID=6yLIpvQqRMGVe8eYUBI8Hw

# --- YouTube (Videos page) ---
# Get a key at https://console.cloud.google.com (enable YouTube Data API v3)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_HANDLE=@officialleokoko

# --- Supabase (Community chat) ---
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
